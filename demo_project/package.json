{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "predeploy": "npm run build && node -e \"require('fs').copyFileSync('dist/index.html', 'dist/404.html'); require('fs').writeFileSync('dist/.nojekyll', ''); require('fs').writeFileSync('dist/.gitignore', '!*.glb')\"",
    "deploy": "gh-pages -b demo -d dist --dotfiles"
  },
  "dependencies": {
